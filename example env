YOUTUBE_API_KEY=APIKeyGoesHere

# Either of these works; CHANNEL_ID takes priority if present
CHANNEL_ID=TargetChannelIDGoesHere
CHANNEL_HANDLE=@YouTubeHandle
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123123/examplelink
MENTION_ROLE_ID=RoleIDToPingGoesHere


# for testing
TEST_CHANNEL_ID=TestChannelIDGoesHere
TEST_CHANNEL_HANDLE=@TestYouTubeHandle
TEST_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123123/testexamplelink
TEST_MENTION_ROLE_ID=TestRoleIDToPingGoesHere

